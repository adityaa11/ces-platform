{
  "name": "ces-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": "24.12.0",
    "pnpm": "11.15.1"
  },
  "scripts": {
    "build": "corepack pnpm --recursive --if-present run build",
    "typecheck": "corepack pnpm --recursive --if-present run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "corepack pnpm typecheck && corepack pnpm test && corepack pnpm build"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
