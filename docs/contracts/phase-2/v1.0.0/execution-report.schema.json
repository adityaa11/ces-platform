{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ces.example/contracts/phase-2/v1.0.0/execution-report.schema.json",
  "title": "CES execution report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "runner_exit_code", "artifacts", "diagnostics"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "status": { "enum": ["success", "input_error", "execution_error", "blocked", "conflict", "adapter_gap"] },
    "runner_exit_code": { "type": "integer", "minimum": 0, "maximum": 255 },
    "phase_1_exit_code": { "enum": [0, 2, 3, 4, 5] },
    "requirement_id": { "type": "string", "minLength": 1 },
    "compilation_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "ces": { "type": "object", "additionalProperties": false, "required": ["commit"], "properties": { "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" } } },
    "adapter": { "type": "object", "additionalProperties": false, "required": ["id", "version"], "properties": { "id": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 } } },
    "artifacts": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "core": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/relativePath" } },
        "adapter": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/relativePath" } }
      }
    },
    "diagnostics": { "type": "array", "items": { "$ref": "diagnostic.schema.json" } }
  },
  "$defs": { "relativePath": { "type": "string", "minLength": 1, "not": { "anyOf": [{ "pattern": "^[A-Za-z]:" }, { "pattern": "^[\\\\/]" }, { "pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)" }] } } },
  "allOf": [
    { "if": { "required": ["phase_1_exit_code"] }, "then": { "oneOf": [
      { "properties": { "phase_1_exit_code": { "const": 0 }, "runner_exit_code": { "const": 0 }, "status": { "const": "success" } } },
      { "properties": { "phase_1_exit_code": { "const": 2 }, "runner_exit_code": { "const": 2 }, "status": { "const": "input_error" } } },
      { "properties": { "phase_1_exit_code": { "const": 3 }, "runner_exit_code": { "const": 3 }, "status": { "const": "blocked" } } },
      { "properties": { "phase_1_exit_code": { "const": 4 }, "runner_exit_code": { "const": 4 }, "status": { "const": "conflict" } } },
      { "properties": { "phase_1_exit_code": { "const": 5 }, "runner_exit_code": { "const": 5 }, "status": { "const": "adapter_gap" } } }
    ] }, "else": { "properties": { "status": { "enum": ["input_error", "execution_error"] }, "artifacts": { "maxProperties": 0 } } } }
  ]
}
