{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ces.example/contracts/phase-2/v1.0.0/diagnostic.schema.json",
  "title": "CES Phase 2 diagnostic",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "source", "severity", "message"],
  "properties": {
    "code": { "type": "string", "pattern": "^CES_[A-Z0-9_]+$" },
    "source": { "enum": ["phase_2_runner", "phase_1_exit_code", "policy_manifest", "adapter_report"] },
    "severity": { "enum": ["error", "warning", "info"] },
    "message": { "type": "string", "minLength": 1 },
    "policy_id": { "type": "string", "minLength": 1 },
    "requirement_id": { "type": "string", "minLength": 1 },
    "rule_id": { "type": "string", "minLength": 1 },
    "field_path": { "type": "string", "minLength": 1 },
    "adapter_id": { "type": "string", "minLength": 1 },
    "details": { "type": "object" }
  }
}
